# =============================================================
# BeeChat API - Variables de Entorno
# Copiar este archivo como .env y completar los valores reales
# =============================================================

# ---- Servidor ----
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ---- Base de Datos (SQL Server) ----
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=BeeChat
DB_USER=sa
DB_PASSWORD=TuPasswordAqui
DB_ENCRYPT=false
DB_TRUST_CERT=true
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000

# ---- JWT ----
# Genera strings aleatorios de 64+ caracteres para producción
JWT_ACCESS_SECRET=cambia_esto_a_un_string_aleatorio_de_64_caracteres_minimo_acceso
JWT_REFRESH_SECRET=cambia_esto_a_otro_string_aleatorio_de_64_caracteres_diferente_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- CORS ----
# Separar múltiples orígenes con coma
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:19000,http://localhost:8081

# ---- Uploads ----
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
MAX_VIDEO_SIZE_MB=50
MAX_AUDIO_SIZE_MB=10
MAX_DOCUMENT_SIZE_MB=20

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Bee Assist (IA - Opcional) ----
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_ENABLED=false

# ---- Logging ----
LOG_LEVEL=debug
LOG_FILE=logs/app.log
